# Copy to .env.local and fill in from your Supabase project settings (API section).

# Used by the dashboard (read-only; RLS allows select only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Used by the device/phone bridge to call the ingest_trip RPC — NOT by the
# dashboard. Keep it out of client bundles; never prefix with NEXT_PUBLIC_.
# SUPABASE_SECRET_KEY=sb_secret_...
